models:
- name: dim_customers
  description: This model consolidates customer information and their order history,
    providing a comprehensive view of each customer including their first and most
    recent order dates, as well as the total number of orders placed.
  columns:
  - name: customer_id
    description: A unique identifier for each customer.
  - name: first_name
    description: The first name of the customer.
  - name: last_name
    description: The last name of the customer.
  - name: first_order_date
    description: The date when the customer placed their first order.
  - name: most_recent_order_date
    description: The date when the customer placed their most recent order.
  - name: number_of_orders
    description: The total number of orders placed by the customer.
- name: fct_orders
  description: This model provides a refined view of orders, including key details
    such as order ID, customer ID, order date, and status. It is designed to facilitate
    analysis of order data by providing a clean and consistent structure.
  columns:
  - name: order_id
    description: A unique identifier for each order.
  - name: customer_id
    description: The identifier for the customer who placed the order.
  - name: order_date
    description: The date when the order was placed.
  - name: status
    description: The current status of the order.
